generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  organizations    OrganizationMember[]
  activities       ActivityLog[]
  notifications    Notification[]
  approvedBoms     BillOfMaterial[]
  approvedOrders   Order[]            @relation("ApprovedOrders")
  approvedInvoices Invoice[]          @relation("ApprovedInvoices")
  approvedQuotations Quotation[]      @relation("ApprovedQuotations")
  tasks              Task[]
  apiKeys            ApiKey[]
  auditEntries       AuditEntry[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members         OrganizationMember[]
  warehouses      Warehouse[]
  products        Product[]
  categories      Category[]
  suppliers       Supplier[]
  distributors    Distributor[]
  customers       Customer[]
  orders          Order[]
  quotations      Quotation[]
  invoices        Invoice[]
  payments        Payment[]
  discounts       DiscountRule[]
  activityLogs    ActivityLog[]
  notifications   Notification[]
  bomItems        BillOfMaterial[]
  lots            Lot[]
  forecastEntries ForecastEntry[]
  settings        OrganizationSetting?
  deliveries      Delivery[]
  stockCounts     StockCount[]
  workCenters     WorkCenter[]
  operations      Operation[]
  productionOrders ProductionOrder[]
  projects        Project[]
  tasks           Task[]
  workflows       WorkflowDefinition[]
  accountGroups   AccountGroup[]
  accounts        ChartOfAccount[]
  journalEntries  JournalEntry[]
  taxRates        TaxRate[]
  wikiArticles    WikiArticle[]
  knowledgeDocuments KnowledgeDocument[]
  trainingPrograms   TrainingProgram[]
  roles           Role[]
  apiKeys         ApiKey[]
  auditEntries    AuditEntry[]
  stockMovements  StockMovement[]
  aiExecutionLogs AiExecutionLog[]
  agentRuns       AgentRun[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  role           String   @default("admin")
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model Role {
  /// A custom role with granular permission JSON per entity/action
  id             String   @id @default(cuid())
  name           String
  description    String?
  permissions    String   @default("{}")
  isSystem       Boolean  @default(false)
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@unique([name, organizationId])
}

model ApiKey {
  id             String    @id @default(cuid())
  name           String
  keyHash        String    @unique
  keyPrefix      String
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  active         Boolean   @default(true)
  permissions    String    @default("{}")
  userId         String?
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User?        @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

model AuditEntry {
  id             String   @id @default(cuid())
  action         String
  entity         String
  entityId       String
  description    String?
  changes        String?
  ip             String?
  userAgent      String?
  userId         String?
  organizationId String
  createdAt      DateTime @default(now())

  user         User?        @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
  @@index([userId])
}

enum ProductType {
  raw_material
  finished_good
  service
}

enum ProductStatus {
  active
  inactive
  discontinued
}

enum BOMStatus {
  draft
  submitted
  approved
  archived
}

enum QuotationStatus {
  draft
  sent
  confirmed
  expired
  cancelled
}

enum SupplierRating {
  active
  preferred
  inactive
  blacklisted
}

enum StockMovementType {
  received
  sold
  adjusted
  transferred
  returned
  damaged
  issued
  produced
}

enum ProductionOrderStatus {
  draft
  confirmed
  in_progress
  completed
  cancelled
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String
  parentId    String?
  organizationId String
  deletedAt   DateTime?

  parent     Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[]    @relation("CategoryTree")
  products   Product[]
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([slug, organizationId])
}

model Product {
  id          String        @id @default(cuid())
  name        String
  sku         String
  barcode     String?
  description String?
  unitPrice   Float         @default(0)
  costPrice   Float         @default(0)
  currency    String        @default("THB")
  vatStatus   String        @default("exclude_vat")
  stock       Int           @default(0)
  minStock    Int           @default(0)
  maxStock    Int?
  safetyStock Int           @default(0)
  uom         String        @default("pcs")
  leadTime    Int           @default(0)
  weight      Float?
  dimensions  String?
  externalId  String?
  tags        String?
  location    String?
  image       String?
  type        ProductType   @default(finished_good)
  status      ProductStatus @default(active)
  categoryId  String?
  supplierId  String?
  warehouseId String?
  organizationId String
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  category        Category?          @relation(fields: [categoryId], references: [id])
  supplier        Supplier?          @relation(fields: [supplierId], references: [id])
  warehouse       Warehouse?         @relation(fields: [warehouseId], references: [id])
  organization    Organization       @relation(fields: [organizationId], references: [id])
  movements       StockMovement[]
  lots            Lot[]
  orderItems      OrderItem[]
  quotationItems  QuotationItem[]
  invoiceItems    InvoiceItem[]
  bomComponents   BillOfMaterial[]   @relation("BOMComponents")
  bomParents      BillOfMaterial[]   @relation("BOMParents")
  forecastEntries ForecastEntry[]
  supplierPrices  SupplierPrice[]
  deliveryItems   DeliveryItem[]
  stockCountItems StockCountItem[]
  productionOrders ProductionOrder[]
  productionOrderMaterials ProductionOrderMaterial[]

  @@unique([sku, organizationId])
}

model SupplierPrice {
  id         String   @id @default(cuid())
  productId  String
  supplierId String
  price      Float    @default(0)
  currency   String   @default("THB")
  leadTime   Int      @default(0)
  isDefault  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([productId, supplierId])
}

model BillOfMaterial {
  id              String    @id @default(cuid())
  finishedGoodId  String
  materialId      String
  quantity        Float     @default(1)
  scrapAllowance  Float     @default(0)
  unit            String    @default("pcs")
  wastePercent    Float     @default(0)

  version         Int       @default(1)
  status          BOMStatus @default(draft)
  effectiveDate   DateTime?
  expiryDate      DateTime?

  approvedById    String?
  approvedAt      DateTime?
  notes           String?
  createdById     String?
  organizationId  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  finishedGood Product       @relation("BOMParents", fields: [finishedGoodId], references: [id])
  material     Product       @relation("BOMComponents", fields: [materialId], references: [id])
  approvedBy   User?         @relation(fields: [approvedById], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id])
  operations   Operation[]
  prodOrders   ProductionOrder[]

  @@unique([finishedGoodId, materialId, version])
}

model Lot {
  id            String   @id @default(cuid())
  number        String
  productId     String
  supplierId    String?
  receivedDate  DateTime @default(now())
  expiryDate    DateTime?
  quantity      Int      @default(0)
  costPrice     Float?
  notes         String?
  organizationId String
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product      Product      @relation(fields: [productId], references: [id])
  supplier     Supplier?    @relation(fields: [supplierId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  movements    StockMovement[]
}

model ForecastEntry {
  id               String   @id @default(cuid())
  productId        String
  date             DateTime
  forecastQuantity Int      @default(0)
  actualQuantity   Int      @default(0)
  confidence       Float?
  notes            String?
  organizationId   String
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product      Product      @relation(fields: [productId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

model Warehouse {
  id          String   @id @default(cuid())
  name        String
  location    String?
  capacity    Int?
  organizationId String
  binLocation String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  products     Product[]
  stockMovements StockMovement[]
  deliveries   Delivery[]
  stockCounts  StockCount[]
  prodOrders   ProductionOrder[]
}

model StockMovement {
  id              String            @id @default(cuid())
  type            StockMovementType
  quantity        Int
  description     String?
  reference       String?
  productId       String
  warehouseId     String?
  orderId         String?
  createdById     String?
  organizationId  String
  createdAt       DateTime          @default(now())

  product      Product    @relation(fields: [productId], references: [id])
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  order        Order?     @relation(fields: [orderId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  lotId        String?
  lot          Lot?       @relation(fields: [lotId], references: [id])
  deliveryId   String?
  delivery     Delivery?  @relation(fields: [deliveryId], references: [id])
}

model Supplier {
  id                String   @id @default(cuid())
  name              String
  email             String?
  phone             String?
  address           String?
  taxId             String?
  contactPerson     String?
  contactPersonRole String?
  preferredChannel  String?
  website           String?
  paymentTerms      String?
  currency          String   @default("THB")
  rating            SupplierRating @default(active)
  defaultLeadTime   Int      @default(0)
  documents         String?
  documentsExpiry   DateTime?
  notes             String?
  onTimeDeliveryRate Float?
  qualityRejectRate  Float?
  totalOrders         Int      @default(0)
  organizationId    String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id])
  products       Product[]
  purchaseOrders Order[]        @relation("PurchaseOrders")
  supplierPrices SupplierPrice[]
  lots           Lot[]
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  company     String?
  taxId       String?
  notes       String?
  creditLimit Float?
  organizationId String
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  orders       Order[]      @relation("CustomerOrders")
  quotations   Quotation[]
  invoices     Invoice[]
}

enum OrderStatus {
  draft
  confirmed
  processing
  shipped
  delivered
  cancelled
  returned
}

enum OrderType {
  sales
  purchase
}

model Order {
  id          String     @id @default(cuid())
  number      String
  type        OrderType  @default(sales)
  status      OrderStatus @default(draft)
  subtotal    Float      @default(0)
  tax         Float      @default(0)
  discount    Float      @default(0)
  total       Float      @default(0)
  notes       String?
  orderDate   DateTime   @default(now())
  expectedDate DateTime?
  deliveredAt DateTime?
  customerId    String?
  supplierId    String?
  approvedById  String?
  approvedAt    DateTime?
  deletedAt     DateTime?
  organizationId String
  createdById   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  customer     Customer?       @relation("CustomerOrders", fields: [customerId], references: [id])
  supplier     Supplier?       @relation("PurchaseOrders", fields: [supplierId], references: [id])
  approvedBy   User?           @relation("ApprovedOrders", fields: [approvedById], references: [id])
  organization Organization    @relation(fields: [organizationId], references: [id])
  items        OrderItem[]
  payments     Payment[]
  movements    StockMovement[]
  quotations   Quotation[]
  invoices     Invoice[]
}

model OrderItem {
  id          String  @id @default(cuid())
  quantity    Int     @default(1)
  unitPrice   Float   @default(0)
  total       Float   @default(0)
  receivedQty Int     @default(0)
  invoicedQty Int     @default(0)
  orderId     String
  productId   String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Quotation {
  id          String   @id @default(cuid())
  number      String
  validUntil  DateTime?
  subtotal    Float    @default(0)
  tax         Float    @default(0)
  discount    Float    @default(0)
  total       Float    @default(0)
  notes       String?
  status      QuotationStatus @default(draft)
  approvedById String?
  approvedAt   DateTime?
  customerId  String
  orderId     String?
  organizationId String
  createdById String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer     Customer        @relation(fields: [customerId], references: [id])
  order        Order?          @relation(fields: [orderId], references: [id])
  approvedBy   User?           @relation("ApprovedQuotations", fields: [approvedById], references: [id])
  organization Organization    @relation(fields: [organizationId], references: [id])
  items        QuotationItem[]
}

model QuotationItem {
  id          String  @id @default(cuid())
  quantity    Int     @default(1)
  unitPrice   Float   @default(0)
  total       Float   @default(0)
  quotationId String
  productId   String

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

model Invoice {
  id          String        @id @default(cuid())
  number      String
  status      InvoiceStatus @default(draft)
  issueDate   DateTime
  dueDate     DateTime
  subtotal    Float         @default(0)
  tax         Float         @default(0)
  discount    Float         @default(0)
  total       Float         @default(0)
  paidAmount    Float         @default(0)
  notes         String?
  customerId    String
  orderId       String?
  approvedById  String?
  approvedAt    DateTime?
  organizationId String
  createdById   String?
  deletedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer     Customer     @relation(fields: [customerId], references: [id])
  order        Order?       @relation(fields: [orderId], references: [id])
  approvedBy   User?        @relation("ApprovedInvoices", fields: [approvedById], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]
}

model InvoiceItem {
  id        String  @id @default(cuid())
  description String
  quantity  Int     @default(1)
  unitPrice Float   @default(0)
  total     Float   @default(0)
  invoiceId String
  productId String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

enum PaymentMethod {
  cash
  bank_transfer
  credit_card
  cheque
  other
}

model Payment {
  id          String        @id @default(cuid())
  amount      Float
  date        DateTime
  method      PaymentMethod @default(bank_transfer)
  reference   String?
  notes       String?
  invoiceId   String?
  orderId     String?
  organizationId String
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  invoice      Invoice?      @relation(fields: [invoiceId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id])
}

enum DiscountType {
  percentage
  fixed_amount
}

model DiscountRule {
  id          String       @id @default(cuid())
  name        String
  description String?
  type        DiscountType @default(percentage)
  value       Float
  minPurchase Float?
  active      Boolean      @default(true)
  organizationId String
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

enum ActivityAction {
  created
  updated
  deleted
  approved
  rejected
  submitted
  archived
  versioned
  paid
  received
  shipped
  adjusted
  transferred
  restored
  converted
}

model ActivityLog {
  id        String         @id @default(cuid())
  action    ActivityAction
  entity    String
  entityId  String
  message   String
  metadata  String?
  userId    String?
  organizationId String
  createdAt DateTime       @default(now())

  user         User?        @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

enum NotificationType {
  info
  success
  warning
  error
  low_stock
  order
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType @default(info)
  title     String
  message   String?
  link      String?
  read      Boolean          @default(false)
  userId    String
  organizationId String
  deletedAt DateTime?
  createdAt DateTime         @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
}

model OrganizationSetting {
  id              String   @id @default(cuid())
  currency        String   @default("THB")
  taxRate         Float    @default(7)
  dateFormat      String   @default("DD/MM/YYYY")
  timezone        String   @default("Asia/Bangkok")
  lowStockThreshold Int    @default(10)
  onboardingCompleted Boolean @default(false)
  planId          String   @default("free")
  stripeCustomerId String?
  stripeSubscriptionId String?
  organizationId  String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum DistributorStatus {
  active
  inactive
  suspended
}

enum DeliveryStatus {
  draft
  packing
  shipped
  in_transit
  delivered
  failed
  cancelled
}

enum StockCountStatus {
  draft
  in_progress
  completed
  cancelled
}

model Distributor {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  address       String?
  taxId         String?
  contactPerson String?
  territory     String?
  route         String?
  contractStart DateTime?
  contractEnd   DateTime?
  status        DistributorStatus @default(active)
  notes         String?
  organizationId String
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  deliveries   Delivery[]
}

model Delivery {
  id              String        @id @default(cuid())
  number          String
  status          DeliveryStatus @default(draft)
  trackingNumber  String?
  carrier         String?
  estimatedDate   DateTime?
  actualDate      DateTime?
  notes           String?
  origin          String?
  destination     String?
  totalItems      Int           @default(0)
  totalValue      Float         @default(0)
  distributorId   String
  warehouseId     String?
  createdById     String?
  organizationId  String
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  distributor Distributor       @relation(fields: [distributorId], references: [id])
  warehouse   Warehouse?        @relation(fields: [warehouseId], references: [id])
  organization Organization     @relation(fields: [organizationId], references: [id])
  items       DeliveryItem[]
  tracking    DeliveryTracking[]
  movements   StockMovement[]
}

model DeliveryItem {
  id          String  @id @default(cuid())
  quantity    Int     @default(1)
  deliveredQty Int    @default(0)
  unitPrice   Float   @default(0)
  total       Float   @default(0)
  deliveryId  String
  productId   String

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
}

model DeliveryTracking {
  id        String   @id @default(cuid())
  status    DeliveryStatus
  location  String?
  note      String?
  timestamp DateTime @default(now())
  deliveryId String

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model StockCount {
  id            String          @id @default(cuid())
  number        String
  status        StockCountStatus @default(draft)
  countDate     DateTime        @default(now())
  totalItems    Int             @default(0)
  matchedItems  Int             @default(0)
  discrepancyItems Int          @default(0)
  notes         String?
  warehouseId   String
  countedById   String?
  organizationId String
  deletedAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id])
  organization Organization      @relation(fields: [organizationId], references: [id])
  items        StockCountItem[]
}

model StockCountItem {
  id           String  @id @default(cuid())
  expectedQty  Int     @default(0)
  actualQty    Int     @default(0)
  difference   Int     @default(0)
  notes        String?
  stockCountId String
  productId    String

  stockCount StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])
}

model WorkCenter {
  id             String   @id @default(cuid())
  code           String
  name           String
  description    String?
  costPerHour    Float    @default(0)
  capacity       Int      @default(1)
  location       String?
  isActive       Boolean  @default(true)
  organizationId String
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  operations   Operation[]
  orderOps     ProductionOrderOperation[]
}

model Operation {
  id           String  @id @default(cuid())
  name         String
  sequence     Int     @default(0)
  description  String?
  setupTime    Float   @default(0)
  runTime      Float   @default(0)
  workCenterId String
  bomId        String?
  organizationId String
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workCenter   WorkCenter @relation(fields: [workCenterId], references: [id])
  bom          BillOfMaterial? @relation(fields: [bomId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

model ProductionOrder {
  id              String                @id @default(cuid())
  number          String
  status          ProductionOrderStatus @default(draft)
  productId       String
  bomId           String?
  quantity        Int                   @default(1)
  producedQty     Int                   @default(0)
  startDate       DateTime?
  dueDate         DateTime?
  completedDate   DateTime?
  notes           String?
  warehouseId     String?
  createdById     String?
  organizationId  String
  deletedAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  product      Product                   @relation(fields: [productId], references: [id])
  bom          BillOfMaterial?           @relation(fields: [bomId], references: [id])
  warehouse    Warehouse?                @relation(fields: [warehouseId], references: [id])
  organization Organization              @relation(fields: [organizationId], references: [id])
  materials    ProductionOrderMaterial[]
  operations   ProductionOrderOperation[]
}

model ProductionOrderMaterial {
  id             String  @id @default(cuid())
  productId      String
  quantityNeeded Int     @default(0)
  quantityIssued Int     @default(0)
  orderId        String

  product      Product         @relation(fields: [productId], references: [id])
  productionOrder ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ProductionOrderOperation {
  id           String   @id @default(cuid())
  sequence     Int      @default(0)
  name         String
  setupTime    Float    @default(0)
  runTime      Float    @default(0)
  executedAt   DateTime?
  workCenterId String
  orderId      String

  workCenter     WorkCenter      @relation(fields: [workCenterId], references: [id])
  productionOrder ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// === FINANCE MODULE ===

enum AccountGroupType {
  asset
  liability
  equity
  revenue
  expense
  contra_asset
  contra_liability
  contra_equity
}

model AccountGroup {
  id             String          @id @default(cuid())
  name           String
  type           AccountGroupType
  code           String
  description    String?
  parentId       String?
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization                  @relation(fields: [organizationId], references: [id])
  parent       AccountGroup?                 @relation("AccountGroupParent", fields: [parentId], references: [id])
  children     AccountGroup[]                @relation("AccountGroupParent")
  accounts     ChartOfAccount[]
}

model ChartOfAccount {
  id              String          @id @default(cuid())
  code            String
  name            String
  type            AccountGroupType
  isActive        Boolean         @default(true)
  openingBalance  Float           @default(0)
  currentBalance  Float           @default(0)
  groupId         String
  organizationId  String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  group          AccountGroup    @relation(fields: [groupId], references: [id])
  organization   Organization    @relation(fields: [organizationId], references: [id])
  journalLines   JournalLine[]
}

model JournalEntry {
  id              String          @id @default(cuid())
  number          String
  date            DateTime        @default(now())
  description     String?
  referenceType   String?         // "invoice", "payment", "order", etc.
  referenceId     String?
  totalDebit      Float           @default(0)
  totalCredit     Float           @default(0)
  status          String          @default("posted") // "draft", "posted"
  organizationId  String
  createdById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id])
  lines           JournalLine[]
}

model JournalLine {
  id              String          @id @default(cuid())
  accountId       String
  debit           Float           @default(0)
  credit          Float           @default(0)
  description     String?
  entryId         String

  entry           JournalEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account         ChartOfAccount  @relation(fields: [accountId], references: [id])
}

// === TAX MODULE ===

model TaxRate {
  id             String   @id @default(cuid())
  name           String
  rate           Float
  type           String   @default("vat") // "vat", "withholding", "other"
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
}

// === PROJECT MODULE ===

enum ProjectStatus {
  draft
  active
  paused
  completed
  cancelled
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  status         ProjectStatus @default(draft)
  priority       String        @default("medium")
  startDate      DateTime?
  dueDate        DateTime?
  completedDate  DateTime?
  budget         Float         @default(0)
  actualCost     Float         @default(0)
  organizationId String
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id])
  tasks          Task[]
}

model Task {
  id              String     @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus @default(todo)
  priority        String     @default("medium")
  assigneeId      String?
  dueDate         DateTime?
  estimatedHours  Float      @default(0)
  actualHours     Float      @default(0)
  projectId       String
  organizationId  String
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id])
  assignee       User?        @relation(fields: [assigneeId], references: [id])
}

// === WORKFLOW ENGINE ===

model WorkflowDefinition {
  id             String   @id @default(cuid())
  name           String
  entityType     String   // "order", "invoice", "production_order"
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id])
  states         WorkflowState[]
  transitions    WorkflowTransition[]
}

model WorkflowState {
  id         String   @id @default(cuid())
  name       String
  color      String   @default("#6b7280")
  isInitial  Boolean  @default(false)
  isFinal    Boolean  @default(false)
  workflowId String
  createdAt  DateTime @default(now())

  workflow        WorkflowDefinition     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  transitionsFrom WorkflowTransition[]   @relation("TransitionFrom")
  transitionsTo   WorkflowTransition[]   @relation("TransitionTo")
}

model WorkflowTransition {
  id           String   @id @default(cuid())
  name         String
  fromStateId  String
  toStateId    String
  workflowId   String
  requiredRole String?
  createdAt    DateTime @default(now())

  fromState WorkflowState       @relation("TransitionFrom", fields: [fromStateId], references: [id], onDelete: Cascade)
  toState   WorkflowState       @relation("TransitionTo", fields: [toStateId], references: [id], onDelete: Cascade)
  workflow  WorkflowDefinition  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

// === KNOWLEDGE MODULE (DB-persisted) ===

model WikiArticle {
  id             String   @id @default(cuid())
  title          String
  category       String
  excerpt        String?
  author         String   @default("Admin")
  updated        String   @default("now")
  readTime       String   @default("3 min")
  content        String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model KnowledgeDocument {
  id             String   @id @default(cuid())
  name           String
  type           String   @default("Other")
  fileType       String   @default("pdf")
  size           String   @default("0 KB")
  filePath       String   @default("")
  uploadedBy     String   @default("Admin")
  uploadedAt     String
  relatedTo      String?
  notes          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model AiExecutionLog {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  toolName       String
  input          Json
  output         Json?
  status         String   @default("success")
  errorMessage   String?
  durationMs     Int?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  action         String   @default("tool_execution")
  agentId        String?
  provider       String?
  model          String?
  inputTokens    Int?
  outputTokens   Int?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([toolName, createdAt])
}

model AgentRun {
  id             String    @id @default(cuid())
  agentId        String
  agentName      String
  organizationId String
  userId         String
  task           String
  status         String    @default("idle")
  summary        String?
  error          String?
  startedAt      DateTime
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  steps         AgentStep[]
  approvals     AgentApproval[]

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([agentId, createdAt])
  @@index([status])
}

model AgentStep {
  id         String   @id @default(cuid())
  runId      String
  toolName   String
  status     String   @default("pending")
  input      Json
  output     Json?
  durationMs Int?
  createdAt  DateTime @default(now())

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

model AgentApproval {
  id          String    @id @default(cuid())
  runId       String
  toolName    String
  status      String    @default("pending")
  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([status])
}

model TrainingProgram {
  id             String   @id @default(cuid())
  title          String
  type           String   @default("Course")
  level          String   @default("Beginner")
  modules        Int      @default(1)
  duration       String   @default("1 hour")
  students       Int      @default(0)
  progress       Int      @default(0)
  description    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model Folder {
  id            String   @id @default(cuid())
  name          String
  parentId      String?
  workspaceId   String
  createdBy     String
  organizationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  parent        Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  children      Folder[] @relation("FolderTree")
  files         File[]
  organization  Organization @relation(fields: [organizationId], references: [id])

  @@unique([name, parentId, organizationId])
  @@index([organizationId])
  @@index([parentId])
}

model File {
  id            String   @id @default(cuid())
  name          String
  folderId      String
  content       String   @default("")
  type          String   @default("text")
  createdBy     String
  organizationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  folder        Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [organizationId], references: [id])

  @@unique([name, folderId])
  @@index([organizationId])
  @@index([folderId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  organizationId String
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  entities   EntityTag[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model EntityTag {
  id         String   @id @default(cuid())
  tagId      String
  entityId   String
  entityType String
  createdAt  DateTime @default(now())

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, entityId, entityType])
  @@index([entityId, entityType])
  @@index([tagId])
}
